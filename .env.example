# =====================================================
# i1 CCTV — Sistem Internal Toko
# Salin file ini menjadi .env.local (untuk lokal) lalu isi nilainya.
# Untuk Vercel: masukkan nilai yang sama di Project Settings → Environment Variables.
# =====================================================

# ---------- Supabase (Database & Auth) ----------
# Ambil dari Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# JANGAN pernah expose key ini ke browser / commit ke git.
# Hanya dipakai di server (API routes & script seed).
SUPABASE_SERVICE_ROLE_KEY=
